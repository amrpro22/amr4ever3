<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>صندوق مساعدة الحالات الطارئة</title>
    
    <!-- تحميل خط تجوال من Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
    
    <!-- تحميل Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- تخصيص إعدادات Tailwind لتشمل الخط المخصص وألوان محددة -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Tajawal', 'sans-serif'],
                    },
                    colors: {
                        primary: '#001f54',
                        secondary: '#003b8e',
                        accent: '#d4a84f',
                        gold: '#c89b3c'
                    }
                }
            }
        }
    </script>

    <style>
        body {
            font-family: 'Tajawal', sans-serif;
            background-color: #f0f4f8;
            background-image: radial-gradient(#cbd5e1 1px, transparent 1px);
            background-size: 20px 20px;
        }
        
        .fade-in {
            animation: fadeIn 0.4s ease-in-out;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* تخصيص شريط التمرير */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1; 
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1; 
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8; 
        }
    </style>
</head>

<body class="min-h-screen flex justify-center items-center p-4 sm:p-6 md:p-10">

    <div class="w-full max-w-4xl bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100 flex flex-col">
        
        <!-- الهيدر -->
        <header class="bg-gradient-to-r from-primary to-secondary text-white relative overflow-hidden py-12 px-6 text-center shadow-md border-b-4 border-gold">
            <!-- زخرفة خلفية -->
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-white opacity-5 rounded-full blur-2xl"></div>
            <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-accent opacity-10 rounded-full blur-2xl"></div>
            
            <div class="relative z-10 flex flex-col items-center justify-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-14 w-14 text-accent mb-2 drop-shadow-md" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
                <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight drop-shadow-lg">صندوق مساعدة الحالات الطارئة</h1>
                <p class="text-accent text-lg md:text-xl font-medium mt-2 drop-shadow">معاً نخفف الألم ونرسم الأمل</p>
            </div>
        </header>

        <!-- المحتوى -->
        <main class="flex-grow p-6 md:p-10">
            
            <!-- قسم البحث -->
            <div class="mb-8 bg-gray-50 p-6 rounded-2xl border border-gray-100 shadow-inner">
                <label for="searchInput" class="block mb-3 text-lg md:text-xl font-bold text-primary">البحث باسم المتبرع</label>
                <div class="flex flex-col md:flex-row gap-4">
                    <div class="relative flex-grow">
                        <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <input 
                            type="text" 
                            id="searchInput" 
                            class="w-full pl-4 pr-12 py-4 rounded-xl border-2 border-gray-200 focus:border-accent focus:ring-4 focus:ring-accent/20 text-gray-700 text-lg transition-all outline-none shadow-sm"
                            placeholder="اكتب اسم المتبرع كاملاً هنا..."
                            onkeypress="handleKeyPress(event)"
                        >
                    </div>
                    <button 
                        onclick="searchDonor()" 
                        class="bg-gradient-to-r from-primary to-secondary hover:from-secondary hover:to-blue-700 text-white font-bold text-lg py-4 px-10 rounded-xl shadow-lg transform hover:-translate-y-1 hover:shadow-xl transition-all duration-300 focus:outline-none focus:ring-4 focus:ring-secondary/30 active:translate-y-0 flex justify-center items-center gap-2">
                        <span>بحث</span>
                    </button>
                </div>
            </div>

            <!-- قسم النتائج -->
            <div class="bg-white rounded-2xl border-2 border-dashed border-accent/60 p-6 md:p-8 min-h-[250px]">
                <div class="flex items-center gap-3 mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    <h3 class="text-2xl font-bold text-primary">نتائج البحث</h3>
                </div>

                <!-- حاوية النتائج الديناميكية -->
                <div id="resultsContainer" class="text-center text-gray-500 py-10 flex flex-col items-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-gray-300 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 16l2.879-2.879m0 0a3 3 0 104.243-4.242 3 3 0 00-4.243 4.242zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <p class="text-lg">قم بكتابة اسم المتبرع في حقل البحث لإظهار البيانات.</p>
                </div>
            </div>

        </main>

        <!-- الفوتر -->
        <footer class="bg-slate-50 border-t border-gray-200 p-6 text-center">
            <p class="text-primary font-bold text-lg flex items-center justify-center gap-2">
                اللهم اجعل ما قدموه في ميزان حسناتهم 
                <span class="text-red-500 animate-pulse">🤍</span>
            </p>
            <!-- إضافة حقوق التصميم -->
            <div class="mt-4 pt-4 border-t border-gray-200 inline-block">
                <p class="text-sm text-gray-600 font-medium">
                    تم التصميم بواسطة <span class="text-secondary font-extrabold text-base">عمرو مسعد الشجاع</span>
                </p>
            </div>
        </footer>

    </div>

    <script>
        // بيانات المتبرعين
        const donors = [
            { name: "مصطفى الشجاع", note: "تبرع بمبلغ 200 دولار ✅ يمني لمدة 6 أشهر." },
            { name: "أحمد بن أحمد الشجاع", note: "تبرع بمبلغ 200 دولار." },
            { name: "نضال أحمد الشجاع", note: "تبرع بمبلغ 100 دولار." },
            { name: "مفيد الغزالي", note: "تبرع بمبلغ 100 دولار." },
            { name: "بدر الشجاع وإخوانه", note: "تبرع بمبلغ 75 دولار." },
            { name: "محمد علي ناجي الشجاع", note: "تبرع بمبلغ 50 دولار ✅ مدفوع 6 أشهر." },
            { name: "معاد الشجاع", note: "تبرع بمبلغ 50 دولار ✅ مدفوع 6 أشهر." },
            { name: "رافع الشجاع", note: "تبرع بمبلغ 50 دولار ✅ مدفوع 6 أشهر." },
            { name: "أشرف الشجاع", note: "تبرع بمبلغ 50 دولار ✅ مدفوع 6 أشهر." },
            { name: "فاعلة خير", note: "تبرعت بمبلغ 50 دولار ✅ مدفوع 6 أشهر." },
            { name: "نبيل الشجاع", note: "تبرع بمبلغ 50 دولار." },
            { name: "علي عبده مسعد", note: "تبرع بمبلغ 50 دولار." },
            { name: "تمام علي الشجاع", note: "تبرع بمبلغ 50 دولار." },
            { name: "زكريا حزام الشجاع", note: "تبرع بمبلغ 50 دولار." },
            { name: "عبد الملك نبيل الشجاع", note: "تبرع بمبلغ 50 دولار." },
            { name: "عزيز محمد عبد الله", note: "تبرع بمبلغ 25 دولار." },
            { name: "عمار مطهر الشجاع", note: "تبرع بمبلغ 25 دولار." },
            { name: "همدان أحمد الشجاع", note: "تبرع بمبلغ 25 دولار." },
            { name: "مجيد علي ناجي الشجاع", note: "تبرع بمبلغ 25 دولار." },
            { name: "عبد الوهاب أحمد الشجاع", note: "تبرع بمبلغ 25 دولار." },
            { name: "الأمير مصطفى الشجاع", note: "تبرع بمبلغ 20 دولار ✅ مدفوع 6 أشهر." },
            { name: "الأميرة مصطفى الشجاع", note: "تبرعت بمبلغ 20 دولار ✅ مدفوع 6 أشهر." },
            { name: "السلطانة مصطفى الشجاع", note: "تبرعت بمبلغ 20 دولار ✅ مدفوع 6 أشهر." },
            { name: "المصطفى مصطفى الشجاع", note: "تبرع بمبلغ 20 دولار ✅ مدفوع 6 أشهر." },
            { name: "الخليفة مصطفى الشجاع", note: "تبرع بمبلغ 20 دولار ✅ مدفوع 6 أشهر." },
            { name: "سامي خالد الشجاع", note: "تبرع بمبلغ 200 دولار سنوياً." },
            { name: "محمد ناجي الشجاع", note: "تبرع بمبلغ 100 ريال سعودي ✅ مدفوع 6 أشهر." },
            { name: "نايف الشجاع", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "ماجد الشجاع", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "عبدالعزيز عزيز الشجاع", note: "تبرع بمبلغ 50 ألف سنوياً." },
            { name: "معمر علي بن علي", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "محمد السمه", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "طاهر خشخش", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "علي خشخش", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "غانم خشخش", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "محمد أحمد مسعد الشجاع", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "عمرو مسعد الشجاع", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "أحمد صالح خشخش", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "عمار محمد أحمد الشجاع", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "هارون محمد أحمد الشجاع", note: "تبرع بمبلغ 50 ريال سعودي إلى روح عمه عمر." },
            { name: "نجم الدين علي الشجاع", note: "تبرع بمبلغ 50 ريال سعودي." },
            { name: "عزيز ناجي الشجاع", note: "تبرع بمبلغ 25 ريال سعودي." },
            { name: "عدنان صالح الشجاع", note: "تبرع بمبلغ 25 ريال سعودي." },
            { name: "عبد ناجي الشجاع", note: "تبرع بمبلغ 25 ريال سعودي." },
            { name: "فاعل خير عن أمه من طرف محمد ناجي", note: "تبرع بمبلغ 25 ريال سعودي، رحمها الله." },
            { name: "محمد عبد ناجي الشجاع", note: "تبرع بمبلغ 25 ريال سعودي." },
            { name: "إلى روح عمر أحمد خشخش", note: "تبرع بمبلغ 300 ريال سعودي سنوياً ✅ مدفوع 6 أشهر." },
            { name: "محمد ناجي الشجاع - روح والدته مسعدة", note: "تبرع بمبلغ 300 ريال سعودي سنوياً ✅ مدفوع 6 أشهر." },
            { name: "معاذ محمد عبد الشجاع", note: "تبرع بمبلغ 300 ريال سعودي سنوياً." },
            { name: "شايف محمد عبده الشجاع", note: "تبرع بمبلغ 50 ريال سعودي شهرياً." },
            { name: "عبد المجيد ناجي الشجاع", note: "تبرع بمبلغ 300 ريال سعودي سنوياً." },
            { name: "خالد علي خشخش", note: "تبرع بمبلغ 500 ريال سعودي سنوياً." },
            { name: "الدكتور محمد الشجاع", note: "تبرع بمبلغ 120 ألف يمني سنوياً ✅ مدفوع 115 دولار لمدة 6 أشهر." },
            { name: "مهيوب محمد عبدالله الشجاع", note: "تبرع بمبلغ 120 ألف يمني سنوياً." },
            { name: "خالد الشجاع", note: "تبرع بمبلغ 60 ألف يمني سنوياً." },
            { name: "فيصل الشجاع", note: "تبرع بمبلغ 60 ألف يمني سنوياً." },
            { name: "ياسر الشجاع", note: "تبرع بمبلغ 50 ألف يمني سنوياً." },
            { name: "يوسف مهيوب", note: "تبرع بمبلغ 50 ألف يمني سنوياً." },
            { name: "ناصر محمد صالح الشجاع", note: "تبرع بمبلغ 50 ألف يمني سنوياً." },
            { name: "عبد الرحمن علي الشجاع", note: "تبرع بمبلغ 40 ألف يمني سنوياً." },
            { name: "فايز أحمد العمامي", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "حميد عبد علي صالح", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "نعمان أحمد الغزالي", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "محمد عبد الغزالي", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "عز الدين عبد الغزالي", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "عارف عبدالله الحجواني", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "صديق صالح إسماعيل", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "عبد السلام الشجاع", note: "تبرع بمبلغ 36 ألف يمني سنوياً." },
            { name: "أسعد علي ناجي الشجاع", note: "تبرع بمبلغ 10 آلاف يمني سنوياً." },
            { name: "موسى علي الشجاع", note: "تبرع بمبلغ 5000 ريال يمني شهرياً." },
            { name: "عبد اللطيف أحمد الشجاع", note: "تبرع بمبلغ 50 ألف يمني سنوياً." },
            { name: "لطف عبد أحمد الشجاع", note: "تبرع بمبلغ 50 ألف يمني سنوياً." },
            { name: "محمد حزام العمامي", note: "تبرع بمبلغ 50 ألف يمني سنوياً." },
            { name: "علي محمد أحمد محسن", note: "تبرع بمبلغ 36 ألف يمني سنوياً." }
        ];

        
        // دالة للتعامل مع الضغط على زر الإدخال (Enter)
        function handleKeyPress(event) {
            if (event.key === 'Enter') {
                searchDonor();
            }
        }

        // دالة البحث والفلترة
        function searchDonor() {
            const input = document.getElementById("searchInput").value.trim();
            const container = document.getElementById("resultsContainer");
            
            // تفريغ الحاوية وتجهيزها
            container.innerHTML = '';
            container.classList.remove("text-center", "py-10", "items-center", "flex-col");
            container.classList.add("flex", "flex-col", "gap-4");

            // حالة الحقل الفارغ
            if (input === "") {
                container.classList.add("text-center", "py-10", "items-center", "flex-col");
                container.classList.remove("gap-4");
                container.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-yellow-500 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                    <p class="text-lg font-semibold text-gray-700">يرجى كتابة اسم للبحث عنه.</p>
                `;
                return;
            }

            // البحث عن تطابق تام لاسم المتبرع وعدم إظهار الأسماء المشابهة
            const matchingDonors = donors.filter(d => d.name === input);

            if (matchingDonors.length > 0) {
                // إضافة رسالة توضح عدد النتائج
                const countMsg = document.createElement("p");
                countMsg.className = "text-sm text-gray-500 mb-2 fade-in";
                countMsg.innerText = `تم العثور على (${matchingDonors.length}) نتيجة مطابقة:`;
                container.appendChild(countMsg);

                // بناء بطاقة لكل نتيجة
                matchingDonors.forEach((donor, index) => {
                    // تحديد إذا كان المتبرع قد دفع بناءً على وجود علامة ✅ في الملاحظة
                    const isPaid = donor.note.includes('✅');
                    const noteColor = isPaid ? 'bg-green-50 border-green-500 text-green-800' : 'bg-amber-50 border-amber-500 text-amber-900';
                    const iconColor = isPaid ? 'text-green-500' : 'text-amber-500';

                    // إضافة الجمل التحفيزية
                    const motivationalPhrase = isPaid 
                        ? '<span class="block mt-2 text-green-700 font-bold text-sm">بارك الله في مالك وعيالك، شكراً لسرعة استجابتك وعطائك الطيب! 🌟</span>'
                        : '<span class="block mt-2 text-amber-700 font-bold text-sm">ننتظر عطاءك الكريم بشوق.. مساهمتك ستصنع أملاً، بادر بالدفع لتعظيم الأجر! 🚀</span>';

                    const card = document.createElement("div");
                    card.className = `fade-in bg-white p-5 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow relative overflow-hidden`;
                    // تأخير خفيف لكل بطاقة لتعطي تأثير ظهور متسلسل
                    card.style.animationDelay = `${index * 0.05}s`;

                    card.innerHTML = `
                        <div class="absolute top-0 right-0 w-2 h-full ${isPaid ? 'bg-green-500' : 'bg-amber-500'}"></div>
                        <h4 class="text-xl font-bold text-primary mb-3 flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 ${iconColor}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                            ${donor.name}
                        </h4>
                        <div class="${noteColor} p-4 rounded-lg border-r-4 text-base font-medium flex items-start gap-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <div>
                                <p>${donor.note}</p>
                                ${motivationalPhrase}
                            </div>
                        </div>
                    `;
                    container.appendChild(card);
                });
            } else {
                // حالة عدم وجود نتائج
                container.classList.add("text-center", "py-10", "items-center", "flex-col");
                container.classList.remove("gap-4");
                container.innerHTML = `
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-red-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <p class="text-xl font-bold text-primary mb-2">عذراً، لا توجد نتائج!</p>
                    <p class="text-gray-500">لم نتمكن من العثور على متبرع باسم "${input}". تأكد من صحة الإملاء وحاول مجدداً.</p>
                `;
            }
        }
    </script>
</body>
</html>
